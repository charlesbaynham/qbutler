{
  "permissions": {
    "allow": [
      "Bash(git ls-tree *)",
      "Bash(git checkout *)",
      "Bash(git rm *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/clone-deps.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "black {{filePath}} && isort --profile black --force-single-line-imports {{filePath}}"
          }
        ]
      }
    ]
  }
}
